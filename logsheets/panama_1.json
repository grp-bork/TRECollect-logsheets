{
    "id": "panama_1",
    "version": "1.0.0",
    "name": "Panama description",
    "description": "Soil Description Form",
    "fields": [
      {
        "id": "collection_time_start",
        "label": "Collection time start",
        "type": "time",
        "required": true
      },
      {
        "id": "collection_time_end",
        "label": "Collection time end",
        "type": "time",
        "required": true
      },
      {
        "id": "sampling_depth",
        "label": "Sampling depth (cm)",
        "type": "text",
        "default_value": "0-20",
        "required": true
      },
      {
        "id": "soil_square_gps",
        "label": "Soil square GPS coordinates",
        "type": "gps",
        "required": true
      },
      {
        "id": "auger_type",
        "label": "Auger type",
        "type": "select",
        "options": ["Clay", "Sand", "Gravel or rock", "Combi"],
        "required": false
      },
      {
        "id": "auger_number",
        "label": "Auger number",
        "type": "text",
        "required": false
      },
      {
        "id": "elevation",
        "label": "Elevation (m)",
        "type": "text",
        "inputType": "number",
        "required": false
      },
      {
        "id": "first_core_photo",
        "label": "Photo of 1st core of the square",
        "type": "photo",
        "required": false
      },
      {
        "id": "square_photo",
        "label": "Photo of the square",
        "type": "photo",
        "required": false
      },
      {
        "id": "vegetation_type",
        "label": "Vegetation type",
        "type": "select",
        "options": ["forest", "woodland", "scrub", "shrubland", "savanna", "grassland", "meadow", "tundra", "semi-desert", "desert", "no vegetation"],
        "required": false
      },
      {
        "id": "vegetation_subtype",
        "label": "Vegetation subtype",
        "type": "select",
        "options": ["rainforest", "parkland", "thicket", "dwarf scrub", "shrub steppe", "grove savanna", "savanna woodland", "shrub savanna", "steppe", "cold desert"],
        "required": false
      },
      {
        "id": "dominant_tree_species",
        "label": "Dominant tree species",
        "type": "select",
        "options": ["Deciduous", "Coniferous", "Mixed deciduous-coniferous"],
        "required": false
      },
      {
        "id": "density_grassland",
        "label": "Grassland density",
        "type": "select",
        "options": ["no vegetation", "sparse vegetation (less than 50% covered)", "50-99% covered but not high", "fully covered and high"],
        "required": false
      },
      {
        "id": "density_woodland",
        "label": "Woodland density",
        "type": "select",
        "options": ["clearing", "below 5 trees per 100 m^2", "5-20 trees per 100 m^2", "more than 20 trees per 100 m^2"],
        "required": false
      },
      {
        "id": "density_shrubland",
        "label": "Shrubland density",
        "type": "select",
        "options": ["no vegetation", "sparse vegetation (less than 50% covered)", "50-99% covered but not high", "fully covered and high"],
        "required": false
      },
      {
        "id": "litter_depth",
        "label": "Litter depth",
        "type": "select",
        "options": ["no litter", "less than 3 cm", "3-10 cm", "more than 10 cm"],
        "required": false
      },
      {
        "id": "litter_age",
        "label": "Litter age",
        "type": "select",
        "options": ["no litter", "freshly dropped this year", "visible fragments of previous years’ litter", "accumulating for many years"],
        "required": false
      },
      {
        "id": "litter_spatial_homogeneity",
        "label": "Litter spatial homogeneity",
        "type": "select",
        "options": ["no litter", "less than 20% of surface", "20-60% of surface", "above 60% of surface"],
        "required": false
      },
      {
        "id": "geomorphology_of_transect_location",
        "label": "Geomorphology of the location",
        "type": "select",
        "options": ["flat/plateau", "furrow", "slope"],
        "required": false
      },
      {
        "id": "geomorphology_between_squares",
        "label": "Geomorphology of the square",
        "type": "select",
        "options": ["flat", "undulating", "rugged"],
        "required": false
      },
      {
        "id": "slope_angle",
        "label": "Transect slope angle (°)",
        "type": "text",
        "inputType": "number",
        "required": false
      },
      {
        "id": "slope_aspect",
        "label": "Transect slope aspect / exposition",
        "type": "multiselect",
        "options": ["N", "NE", "E", "SE", "S", "SW", "W", "NW"],
        "required": false
      },
      {
        "id": "fauna",
        "label": "Fauna",
        "type": "table",
        "rows": ["earthworms", "ants", "beetle", "millipede", "centipede", "snails"],
        "columns": ["Alive", "Dead"],
        "inputType": "boolean",
        "required": false
      },
      {
        "id": "anthropogenic_pressure",
        "label": "Qualitative assessment of anthropogenic pressure",
        "type": "multiselect",
        "options": ["residential", "agricultural", "industrial", "buildings", "paths for pedestrians", "paths for vehicles", "rubbish", "cigarette butts"],
        "required": false
      },
      {
        "id": "pl_ec_land_classification",
        "label": "The Production-Living-Ecological Land Classification System",
        "type": "select",
        "options": ["Riverine Wetland (Rivers, Inland beach)", "Lacustrine Wetland (Lakes)", "Marshy Wetland (Marshland)", "Human-made Wetland (Reservoir, Pond, Ditches)", "Arbor forest land (Forest land)", "Shrub forest land", "Other forest land", "Natural grassland", "Artificial grassland", "Sightseeing and special land", "Idle land", "Saline land", "Sandy land", "Bare land", "Paddy field", "Arid land (Irrigated land, Agricultural facility land)", "Orchard (Tea garden, Other gardens)", "Industrial & Mineral land (Mining land, Storage land, Port land, Hydraulic Construction land)", "Urban land (Urban, Towns, Urban residential land)", "Rural residence land (Villages)", "Traffic land (Railway land, Highway land, Rural road)"],
        "required": false
      },
      
      {
        "id": "water_moisture",
        "label": "Water - moisture",
        "type": "select",
        "options": ["dry", "fresh", "moist (residual water on hands after handling)", "wet (water is dripping out of it)", "saturated (no soil structure)"],
        "required": false
      },
      {
        "id": "water_hydromorphic_features",
        "label": "Water - hydromorphic features",
        "type": "select",
        "options": ["no sign of permanent water", "some signs of permanent water (orange or grey flecks)", "permanent saturation"],
        "required": false
      },
      {
        "id": "structure_compaction",
        "label": "Structure - compaction",
        "type": "select",
        "options": ["fluffy (hole with no resistance)", "hardly compacted (hole with resistance)", "compact (no hole)", "very compact (stone hard)"],
        "required": false
      },
      {
        "id": "structure_rocks",
        "label": "Structure - rocks",
        "type": "select",
        "options": ["no rocks", "few rocks", "moderate rocks", "full of rocks"],
        "required": false
      },
      {
        "id": "colour_stains",
        "label": "Colour - stain",
        "type": "select",
        "options": ["no stains", "less than 10%", "10-40%", ">40%"],
        "required": false
      },
      {
        "id": "colour_organic_matter",
        "label": "Colour - organic matter",
        "type": "select",
        "options": ["absence", "low (hardly see any dark colour)", "moderate (brown)", "high (dark)"],
        "required": false
      },
      {
        "id": "abundance_of_roots",
        "label": "Abundance of roots",
        "type": "select",
        "options": ["no root", "few roots", "moderate roots", "full of roots"],
        "required": false
      },
      {
        "id": "root_viability",
        "label": "Root viability",
        "type": "select",
        "options": ["all dead", "< 50% alive", "> 50% alive"],
        "required": false
      },
      {
        "id": "soil_texture_visual",
        "label": "Soil Texture (Visual Selection)",
        "type": "multiselect_image",
        "required": false,
        "options": [
          {
            "value": "tap",
            "image": "images/roots_tap.png",
            "label": "Tap"
          },
          {
