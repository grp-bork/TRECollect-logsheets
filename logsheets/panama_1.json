            "label": "Flat"
          },
          {
            "value": "fibrous",
            "image": "images/roots_fibrous.png",
            "label": "Fibrous"
          }
        ]
      },
      {
        "id": "soil_core_colour",
        "label": "Color present in core",
        "type": "multiselect_image",
        "required": false,
        "options": [
          {
            "value": "black",
            "image": "images/colours_black.png",
            "label": "Black"
          },
          {
            "value": "blue_green",
            "image": "images/colours_blue_green.png",
            "label": "Blue/Green"
          },
          {
            "value": "brown",
            "image": "images/colours_brown.png",
            "label": "Brown"
          },
          {
            "value": "dark_brown",
            "image": "images/colours_dark_brown.png",
            "label": "Dark Brown"
          },
          {
            "value": "dark_grey",
            "image": "images/colours_dark_grey.png",
            "label": "Dark Grey"
          },
          {
            "value": "dark_red",
            "image": "images/colours_dark_red.png",
            "label": "Dark Red"
          },
          {
            "value": "light_grey",
            "image": "images/colours_light_grey.png",
            "label": "Light Grey"
          },
          {
            "value": "orange",
            "image": "images/colours_orange.png",
            "label": "Orange"
          },
          {
            "value": "pale_brown",
            "image": "images/colours_pale_brown.png",
            "label": "Pale Brown"
          },
          {
            "value": "pale_yellow",
            "image": "images/colours_pale_yellow.png",
            "label": "Pale Yellow"
          },
          {
            "value": "white",
            "image": "images/colours_white.png",
            "label": "White"
          },
          {
            "value": "yellow",
            "image": "images/colours_yellow.png",
            "label": "Yellow"
          },
          {
            "value": "red",
            "image": "images/colours_red.png",
            "label": "Red"
          }
        ]
      },
      {
        "id": "comments",
        "label": "Comments",
        "type": "textarea",
        "required": false
      }
    ]
  }
